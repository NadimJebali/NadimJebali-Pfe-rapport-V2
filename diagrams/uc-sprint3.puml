@startuml uc-sprint3

skinparam defaultFontName Helvetica
skinparam defaultFontSize 11
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam packageStyle rectangle
skinparam linetype ortho
skinparam nodesep 12
skinparam ranksep 70

skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #1E40AF
  FontColor #1E293B
  FontStyle bold
  FontSize 12
}
skinparam usecase {
  BorderThickness 1.2
  FontColor #1E293B
  FontSize 11
}
skinparam rectangle {
  BackgroundColor #F8FAFC
  BorderColor #1E40AF
  BorderThickness 2
  FontColor #1E40AF
  FontStyle bold
  FontSize 13
}

left to right direction

actor Customer      as Customer
actor Seller        as Seller
actor Administrator as Admin

Customer <|-- Seller

rectangle "Sprint 3 --- Orders, Payment & Administration" {

  rectangle "Orders & Payment" #FFFBEB {
    (Manage cart)           as O1 #FEF3C7
    (Checkout)              as O2 #FEF3C7
    (Pay securely)          as O3 #FEF3C7
    (View store orders)     as O5 #FEF3C7
  }

  rectangle "Account Management" #EFF6FF {
    (Manage profile)        as AC1 #DBEAFE
    (Consult order history) as O4 #DBEAFE
  }

  rectangle "Administration" #FDF2F8 {
    (Moderate stores & products) as D1 #FCE7F3
    (Suspend / delete store)     as D2 #FCE7F3
    (Override AI verdict)        as D3 #FCE7F3
    (Curate featured content)    as D4 #FCE7F3
    (Manage categories)          as D5 #FCE7F3
  }
}

actor "Payment Gateway\n(Stripe)" as PAY  #FEF9C3
actor "Email Service"             as MAIL #FEF9C3

Customer --> O1
Customer --> O2
Customer --> O4
Customer --> AC1
Seller   --> O5
Admin    --> D1
Admin    --> D2
Admin    --> D3
Admin    --> D4
Admin    --> D5

O2 .> O3 : <<include>>
O3 --> PAY
O3 .> MAIL : <<confirmation>>
D2 .> D1 : <<extend>>

@enduml
